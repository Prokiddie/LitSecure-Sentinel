# =============================================
# LITSECURE SENTINEL — ENVIRONMENT TEMPLATE
# =============================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in all REQUIRED values before starting
# 3. NEVER commit .env.local to version control
# 4. Generate secrets with:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================

# =============================================
# REQUIRED — Core Security
# =============================================

# JWT signing secret — MUST be 256-bit random. Rotate every 90 days.
JWT_SECRET=

# JWT token expiry (access token lifetime)
JWT_EXPIRY=8h

# =============================================
# REQUIRED — Google Gemini AI
# =============================================
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# =============================================
# SERVER CONFIG
# =============================================
PORT=3000
NODE_ENV=development

# Logging level: error | warn | info | http | debug
LOG_LEVEL=info

# Application URL (used for OAuth callbacks and CORS in dev)
APP_URL=http://localhost:3000

# PRODUCTION ONLY: comma-separated CORS origin allowlist
# Example: ALLOWED_ORIGINS=https://sentinel.litsecure.mw,https://admin.litsecure.mw
ALLOWED_ORIGINS=

# =============================================
# SUPABASE (Recommended for Production)
# =============================================
# Get from: Supabase Dashboard → Settings → API

# Project URL and keys (PostgREST API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Direct PostgreSQL connection (for pgPool — bypasses PostgREST, full SQL)
# Get from: Supabase Dashboard → Settings → Database → Connection String (URI)
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# Legacy JWT secret (from Supabase project settings if needed)
SUPABASE_JWT_SECRET=

# =============================================
# SMS ALERTS (Africa's Talking)
# =============================================
# Required for USSD/SMS incident reporting and alerts
# Sign up at: https://africastalking.com
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_SENDER_ID=LitSecure
# Comma-separated numbers to receive critical alerts
ALERT_PHONE_NUMBERS=

# =============================================
# EMAIL ALERTS (SMTP)
# =============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=noreply@litsecure.mw
ALERT_EMAIL_TO=

# =============================================
# THREAT INTELLIGENCE FEEDS (All Optional)
# =============================================
# AbuseIPDB: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=

# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AlienVault OTX: https://otx.alienvault.com/api
ALIENVAULT_API_KEY=

# Social Media Monitoring
TWITTER_BEARER_TOKEN=
FACEBOOK_ACCESS_TOKEN=
YOUTUBE_API_KEY=
TIKTOK_CLIENT_KEY=

# =============================================
# BILLING (Paystack)
# =============================================
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# =============================================
# FIRST-RUN ADMIN SEED (Remove after setup)
# =============================================
# Only used during initial database seeding.
# Password policy: 12+ chars, upper + lower + digit + symbol
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# =============================================
# SECURITY CHECKLIST — Before Production
# =============================================
# [ ] JWT_SECRET generated with 256-bit randomness
# [ ] ALLOWED_ORIGINS set to your actual frontend domains
# [ ] SUPABASE_DB_URL points to production DB
# [ ] MFA enabled on all admin accounts
# [ ] HTTPS enforced via reverse proxy (nginx/Caddy)
# [ ] Rotate all API keys quarterly
# [ ] Review audit logs weekly
# [ ] Set up GitHub Actions secrets: SEMGREP_APP_TOKEN, CODECOV_TOKEN, SNYK_TOKEN
